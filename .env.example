# AIMON Framework — Environment Configuration
# Copy this file to .env and fill in your values.
# All values are optional. AIMON runs in demo mode without any keys.

# ── Web Discovery (Google Custom Search) ──────────────────────────────
AIMON_GOOGLE_API_KEY=
AIMON_GOOGLE_SEARCH_ENGINE_ID=

# ── Telegram Scanning ─────────────────────────────────────────────────
# Get from https://my.telegram.org/auth
AIMON_TELEGRAM_API_ID=
AIMON_TELEGRAM_API_HASH=

# ── Graph Storage (Neo4j) ─────────────────────────────────────────────
AIMON_NEO4J_URI=bolt://localhost:7687
AIMON_NEO4J_USER=neo4j
AIMON_NEO4J_PASSWORD=

# ── Cache Storage (Redis) ─────────────────────────────────────────────
AIMON_REDIS_URL=redis://localhost:6379

# ── Database Storage ──────────────────────────────────────────────────
# Default: in-memory (no config needed)
# SQLite:  sqlite+aiosqlite:///aimon.db
# Postgres: postgresql+asyncpg://user:password@localhost/aimon_db
AIMON_DATABASE_URL=

# ── Logging ───────────────────────────────────────────────────────────
AIMON_LOG_LEVEL=INFO
